    "app":  "wkappbot-webbot",
    "title":  "CDP EvalAsync Retry Policy",
    "desc":  "EvalAsync retries up to 3 times on TaskCanceledException or TimeoutException with exponential backoff: 500ms, 1000ms. Attempt 0,1 = retry; attempt 2 = throw.",
    "steps":  [
                  "catch (Exception ex) when (ex is TimeoutException or TaskCanceledException \u0026\u0026 attempt \u003c 2)",
                  "delay = (attempt + 1) * 500  // 500ms then 1000ms",
                  "On attempt \u003e= 2: throw (propagate to caller)"
              ],
