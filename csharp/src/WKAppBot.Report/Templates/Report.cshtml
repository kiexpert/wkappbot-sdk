@model AppBot.Core.Runner.RunResult
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>AppBot Report - @Model.ScenarioName</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'Segoe UI',sans-serif; background:#1a1a2e; color:#e0e0e0; padding:20px; }
  .header { background:#16213e; border-radius:12px; padding:24px; margin-bottom:20px; }
  .header h1 { color:#00d4ff; font-size:24px; margin-bottom:8px; }
  .header .meta { color:#8892b0; font-size:14px; }
  .summary { display:flex; gap:16px; margin-bottom:20px; }
  .summary .card { flex:1; background:#16213e; border-radius:8px; padding:16px; text-align:center; }
  .summary .card .value { font-size:32px; font-weight:bold; }
  .summary .card .label { font-size:12px; color:#8892b0; margin-top:4px; }
  .pass { color:#00e676; }
  .fail { color:#ff5252; }
  .skip { color:#ffc107; }
  table { width:100%; border-collapse:collapse; background:#16213e; border-radius:8px; overflow:hidden; }
  th { background:#0f3460; padding:12px; text-align:left; font-size:13px; color:#8892b0; }
  td { padding:10px 12px; border-top:1px solid #1a1a2e; font-size:13px; }
  tr:hover { background:#1a2744; }
  .badge { display:inline-block; padding:2px 10px; border-radius:12px; font-size:12px; font-weight:600; }
  .badge.pass { background:#00e67622; color:#00e676; }
  .badge.fail { background:#ff525222; color:#ff5252; }
  .footer { text-align:center; color:#444; margin-top:30px; font-size:12px; }
</style>
</head>
<body>

<div class="header">
  <h1>@Model.ScenarioName</h1>
  <div class="meta">
    @Model.StartTime.ToString("yyyy-MM-dd HH:mm:ss") ~ @Model.EndTime.ToString("HH:mm:ss")
    | Duration: @Model.Duration.TotalSeconds.ToString("F1")s
  </div>
</div>

<div class="summary">
  <div class="card">
    <div class="value">@Model.TotalSteps</div>
    <div class="label">Total Steps</div>
  </div>
  <div class="card">
    <div class="value pass">@Model.PassedSteps</div>
    <div class="label">Passed</div>
  </div>
  <div class="card">
    <div class="value fail">@Model.FailedSteps</div>
    <div class="label">Failed</div>
  </div>
  <div class="card">
    <div class="value">@Model.Duration.TotalSeconds.ToString("F1")s</div>
    <div class="label">Duration</div>
  </div>
</div>

<table>
  <thead>
    <tr>
      <th>#</th>
      <th>Step</th>
      <th>Action</th>
      <th>Status</th>
      <th>Time</th>
      <th>Locator</th>
      <th>Message</th>
    </tr>
  </thead>
  <tbody>
    @for (int i = 0; i < Model.Steps.Count; i++)
    {
      var step = Model.Steps[i];
      var statusClass = step.Status == AppBot.Core.Runner.StepStatus.Pass ? "pass" : "fail";
      <tr>
        <td>@(i + 1)</td>
        <td>@step.StepName</td>
        <td>@step.Action</td>
        <td><span class="badge @statusClass">@step.Status</span></td>
        <td>@step.ElapsedMs.ToString("F0")ms</td>
        <td>@(step.LocatorMethod ?? "-")</td>
        <td>@(step.Message ?? "")</td>
      </tr>
    }
  </tbody>
</table>

<div class="footer">
  Generated by AppBot v1.0 (C#) | Powered by Claude
</div>

</body>
</html>
