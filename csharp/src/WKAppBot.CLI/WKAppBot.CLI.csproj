<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows10.0.22621.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>
    <AssemblyName>wkappbot</AssemblyName>
    <RootNamespace>WKAppBot.CLI</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\WKAppBot.Core\WKAppBot.Core.csproj" />
    <ProjectReference Include="..\WKAppBot.Win32\WKAppBot.Win32.csproj" />
    <ProjectReference Include="..\WKAppBot.Vision\WKAppBot.Vision.csproj" />
    <ProjectReference Include="..\WKAppBot.Report\WKAppBot.Report.csproj" />
    <ProjectReference Include="..\WKAppBot.WebBot\WKAppBot.WebBot.csproj" />
  </ItemGroup>

  <!-- Copy handler YAML files from project root to output -->
  <ItemGroup>
    <None Include="..\..\..\handlers\**\*.yaml" CopyToOutputDirectory="PreserveNewest" LinkBase="handlers" />
    <None Include="..\..\..\handlers\**\*.yml" CopyToOutputDirectory="PreserveNewest" LinkBase="handlers" />
  </ItemGroup>

  <!-- Pre-publish: kill running wkappbot.exe to avoid file lock -->
  <Target Name="KillWkappbot" BeforeTargets="Publish">
    <Exec Command="taskkill /IM wkappbot.exe /F" IgnoreExitCode="true" />
  </Target>

  <!-- Single-file publish: copy EXE to W:\SDK\bin, handlers to wkappbot.hq -->
  <Target Name="CopyToSdkBin" AfterTargets="Publish">
    <Copy SourceFiles="$(PublishDir)wkappbot.exe" DestinationFolder="W:\SDK\bin\" OverwriteReadOnlyFiles="true" />
    <Copy SourceFiles="@(_HandlersPublish)" DestinationFolder="W:\SDK\bin\wkappbot.hq\handlers\%(RecursiveDir)" SkipUnchangedFiles="true" />
  </Target>
  <ItemGroup>
    <_HandlersPublish Include="$(PublishDir)handlers\**\*.*" />
  </ItemGroup>

</Project>
