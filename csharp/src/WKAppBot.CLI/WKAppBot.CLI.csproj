<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows10.0.22621.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>
    <AssemblyName>wkappbot</AssemblyName>
    <RootNamespace>WKAppBot.CLI</RootNamespace>
    <UseWPF>true</UseWPF>

    <!-- Deploy-friendly: single self-contained exe so SDK/bin doesn't get DLL clutter -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\WKAppBot.Core\WKAppBot.Core.csproj" />
    <ProjectReference Include="..\WKAppBot.Win32\WKAppBot.Win32.csproj" />
    <ProjectReference Include="..\WKAppBot.Vision\WKAppBot.Vision.csproj" />
    <ProjectReference Include="..\WKAppBot.Report\WKAppBot.Report.csproj" />
    <ProjectReference Include="..\WKAppBot.WebBot\WKAppBot.WebBot.csproj" />
  </ItemGroup>

  <!-- Copy handler YAML files from project root to output + publish -->
  <ItemGroup>
    <Content Include="..\..\..\handlers\**\*.yaml" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" LinkBase="handlers" ExcludeFromSingleFile="true" />
    <Content Include="..\..\..\handlers\**\*.yml" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" LinkBase="handlers" ExcludeFromSingleFile="true" />
  </ItemGroup>

  <!-- Post-publish: kill AppBotEye → copy EXE + handlers to W:\SDK\bin\ -->
  <Target Name="DeployToSdkBin" AfterTargets="Publish">
    <Copy SourceFiles="@(_HandlersPublish)" DestinationFolder="W:\SDK\bin\wkappbot.hq\handlers\%(RecursiveDir)" SkipUnchangedFiles="true" />
    <!-- Kill running AppBotEye so EXE is not locked (best-effort, ignore if not running) -->
    <Exec Command="taskkill /IM wkappbot.exe /F >nul 2>&amp;1 || echo [Deploy] No running wkappbot to kill" IgnoreExitCode="true" />
    <!-- Brief pause for file lock release -->
    <Exec Command="timeout /t 1 /nobreak >nul 2>&amp;1" IgnoreExitCode="true" />
    <!-- Copy EXE (should succeed now that process is killed) -->
    <Exec Command="copy /Y &quot;$(PublishDir)wkappbot.exe&quot; &quot;W:\SDK\bin\wkappbot.exe&quot; >nul 2>&amp;1 &amp;&amp; echo [Deploy] wkappbot.exe updated || ( copy /Y &quot;$(PublishDir)wkappbot.exe&quot; &quot;W:\SDK\bin\wkappbot.new.exe&quot; >nul 2>&amp;1 &amp;&amp; echo [Deploy] Staged as wkappbot.new.exe — manual copy needed )" IgnoreExitCode="true" />
  </Target>
  <ItemGroup>
    <_HandlersPublish Include="$(PublishDir)handlers\**\*.*" />
  </ItemGroup>

</Project>
