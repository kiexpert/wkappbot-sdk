<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>wkappbot</AssemblyName>
    <RootNamespace>WKAppBot.Launcher</RootNamespace>
    <Version>$(WKAppBotVersion)</Version>
    <!-- AOT: native code only, no .NET runtime startup overhead → ~50ms cold start -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishAot>true</PublishAot>
    <PublishTrimmed>true</PublishTrimmed>
    <!-- UTF-8 active code page via manifest: OS sets CP65001 at process load, no runtime API call needed -->
    <ApplicationManifest>app.manifest</ApplicationManifest>
  </PropertyGroup>

  <!-- Post-publish: copy launcher EXE to SDK/bin (no hot-swap needed, rarely changes) -->
  <Target Name="DeployLauncher" AfterTargets="CopyNativeBinary" Condition="'$(SkipDeployLauncher)' != 'true'">
    <!-- Try native copy first (cmd), fall back to xcopy, then robocopy — bash compat -->
    <Exec Command="copy /Y &quot;$(PublishDir)wkappbot.exe&quot; &quot;W:\SDK\bin\wkappbot.exe&quot;" IgnoreExitCode="true" />
    <Exec Command="xcopy /Y &quot;$(PublishDir)wkappbot.exe&quot; &quot;W:\SDK\bin\&quot;" IgnoreExitCode="true" Condition="!Exists('W:\SDK\bin\wkappbot.exe')" />
    <Copy SourceFiles="$(PublishDir)wkappbot.exe" DestinationFiles="W:\SDK\bin\wkappbot.exe" OverwriteReadOnlyFiles="true" />
    <Message Text="[Launcher] wkappbot.exe deployed to W:\SDK\bin\" Importance="high" />
  </Target>

</Project>
